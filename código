<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Minttora — Sesión en Vivo</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Raleway:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --gold:#D4AF37;--gold-b:#F0C040;--gold-d:#8A6A0A;
  --pur:#7B5CF0;--pur-l:#9B79FF;
  --bg:#04040C;
  --ease:cubic-bezier(0.76,0,0.24,1);
}
html,body{width:100%;height:100%;overflow:hidden;background:var(--bg);}
body{font-family:'Raleway',sans-serif;color:#F8F5FF;position:relative;}

#cvRocks{position:fixed;inset:0;z-index:1;pointer-events:none;}
#cvStars{position:fixed;inset:0;z-index:2;pointer-events:none;}
#cvDust {position:fixed;inset:0;z-index:3;pointer-events:none;}
#cvBeams{position:fixed;inset:0;z-index:4;pointer-events:none;}

.vignette{position:fixed;inset:0;z-index:5;pointer-events:none;
  background:radial-gradient(ellipse 88% 82% at 50% 50%,transparent 35%,rgba(4,4,12,0.82) 100%);}
.bg-grid{position:fixed;inset:0;z-index:6;pointer-events:none;
  background-image:
    linear-gradient(rgba(212,175,55,0.018) 1px,transparent 1px),
    linear-gradient(90deg,rgba(212,175,55,0.018) 1px,transparent 1px);
  background-size:80px 80px;
  animation:gridDrift 40s linear infinite;}
@keyframes gridDrift{from{background-position:0 0}to{background-position:80px 80px}}

/* SHELL */
.shell{position:relative;z-index:10;width:100%;height:100vh;display:flex;flex-direction:column;}

/* HEADER */
.hdr{display:flex;align-items:center;justify-content:space-between;
  padding:0 52px;height:76px;flex-shrink:0;
  border-bottom:1px solid rgba(212,175,55,0.1);}
.logo-img{height:40px;object-fit:contain;}
.right-pills{display:flex;align-items:center;gap:14px;}
.live-pill{display:flex;align-items:center;gap:8px;
  background:rgba(255,68,85,0.1);border:1px solid rgba(255,68,85,0.28);
  padding:6px 16px;border-radius:100px;
  font-size:11px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:#FF6677;}
.dot-live{width:7px;height:7px;background:#FF4455;border-radius:50%;animation:blk 1.2s ease-in-out infinite;}
@keyframes blk{0%,100%{opacity:1;box-shadow:0 0 8px #FF4455;}50%{opacity:0.2;}}
.zoom-pill{background:rgba(212,175,55,0.07);border:1px solid rgba(212,175,55,0.18);
  padding:6px 16px;border-radius:100px;font-size:11px;font-weight:500;
  letter-spacing:0.12em;text-transform:uppercase;color:rgba(212,175,55,0.55);}

/* STAGE */
.stage{flex:1;position:relative;overflow:hidden;}

/* COUNTDOWN PANEL */
.cd-panel{position:absolute;top:0;bottom:0;
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;
  transition:left 0.9s var(--ease),right 0.9s var(--ease),width 0.9s var(--ease);
  left:0;right:0;width:100%;}
.cd-panel.shifted{left:auto;right:0;width:44%;}
.cd-label{font-size:10px;font-weight:400;letter-spacing:0.6em;text-transform:uppercase;
  color:rgba(212,175,55,0.4);animation:labelPulse 3s ease-in-out infinite;}
@keyframes labelPulse{0%,100%{opacity:0.4;letter-spacing:0.6em}50%{opacity:0.7;letter-spacing:0.7em}}

/* RING */
.ring-wrap{position:relative;width:280px;height:280px;flex-shrink:0;}
.ring-svg{position:absolute;inset:0;width:100%;height:100%;transform:rotate(-90deg);}
.r-track{fill:none;stroke:rgba(212,175,55,0.07);stroke-width:3;}
.r-prog{fill:none;stroke:url(#gGrad);stroke-width:3;stroke-linecap:round;transition:stroke-dashoffset 1s linear;
  filter:drop-shadow(0 0 6px rgba(212,175,55,0.5));}

/* 5 decorative orbital rings */
.deco-a{position:absolute;inset:-16px;border-radius:50%;border:1px solid rgba(212,175,55,0.12);animation:spin 28s linear infinite;}
.deco-a::before{content:"";position:absolute;top:0;left:50%;transform:translateX(-50%);
  width:8px;height:8px;border-radius:50%;background:var(--gold);
  box-shadow:0 0 12px var(--gold),0 0 28px rgba(212,175,55,0.6),0 0 2px #fff;}
.deco-a::after{content:"";position:absolute;bottom:0;left:50%;transform:translateX(-50%);
  width:5px;height:5px;border-radius:50%;background:rgba(212,175,55,0.5);
  box-shadow:0 0 8px var(--gold);}
.deco-b{position:absolute;inset:12px;border-radius:50%;
  border:1px dashed rgba(212,175,55,0.07);animation:spin 18s linear infinite reverse;}
.deco-b::before{content:"";position:absolute;right:0;top:50%;transform:translateY(-50%);
  width:6px;height:6px;border-radius:50%;background:rgba(240,192,64,0.6);
  box-shadow:0 0 8px #F0C040;}
.deco-c{position:absolute;inset:-36px;border-radius:50%;
  border:1px solid rgba(212,175,55,0.04);animation:spin 50s linear infinite;}
.deco-c::before{content:"";position:absolute;top:30%;right:0;
  width:4px;height:4px;border-radius:50%;background:rgba(212,175,55,0.35);
  box-shadow:0 0 6px var(--gold);}
@keyframes spin{from{transform:rotate(0)}to{transform:rotate(360deg)}}

.time-center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;}
#timeDisp{font-family:"Cinzel",serif;font-size:72px;font-weight:700;line-height:1;
  background:linear-gradient(145deg,#F0C040 0%,#D4AF37 50%,#A8821A 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  letter-spacing:-2px;filter:drop-shadow(0 0 20px rgba(212,175,55,0.4));
  animation:timePulse 1s ease-in-out;}
@keyframes timePulse{0%{filter:drop-shadow(0 0 30px rgba(212,175,55,0.9))}100%{filter:drop-shadow(0 0 20px rgba(212,175,55,0.4))}}
#unitDisp{font-size:10px;font-weight:300;letter-spacing:0.55em;text-transform:uppercase;color:rgba(212,175,55,0.35);}

/* SCANLINE that sweeps over ring */
.ring-scan{position:absolute;inset:0;border-radius:50%;overflow:hidden;pointer-events:none;
  animation:scanSpin 4s linear infinite;}
.ring-scan::before{content:"";position:absolute;left:0;right:0;
  top:50%;height:1px;background:linear-gradient(90deg,transparent,rgba(212,175,55,0.25),transparent);}
@keyframes scanSpin{from{transform:rotate(0)}to{transform:rotate(360deg)}}

/* PULSE RING burst on tick */
.pulse-ring{position:absolute;inset:0;border-radius:50%;
  border:2px solid rgba(212,175,55,0.4);
  animation:pulseRing 2s ease-out infinite;}
.pulse-ring:nth-child(2){animation-delay:0.7s;}
.pulse-ring:nth-child(3){animation-delay:1.4s;}
@keyframes pulseRing{
  0%{transform:scale(0.9);opacity:0.5;border-color:rgba(212,175,55,0.4);}
  100%{transform:scale(1.35);opacity:0;border-color:rgba(212,175,55,0);}
}

/* MESSAGE PANEL */
.msg-panel{position:absolute;top:0;bottom:0;left:0;width:52%;
  display:flex;align-items:center;justify-content:center;padding:40px 48px 40px 52px;
  opacity:0;pointer-events:none;transform:translateX(-60px);
  transition:opacity 0.8s var(--ease),transform 0.9s var(--ease);}
.msg-panel.visible{opacity:1;pointer-events:all;transform:translateX(0);}
.msg-card-big{width:100%;
  background:rgba(8,6,18,0.78);
  border:1px solid rgba(212,175,55,0.22);
  backdrop-filter:blur(22px);
  border-radius:24px;padding:44px 48px;position:relative;overflow:hidden;}
.msg-card-big::before{content:"";position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,transparent,var(--gold),transparent);
  animation:scanBar 3s ease-in-out infinite;}
@keyframes scanBar{0%,100%{opacity:0.6}50%{opacity:1;box-shadow:0 0 12px var(--gold)}}
.msg-card-big::after{content:"";position:absolute;inset:0;border-radius:24px;
  background:radial-gradient(ellipse 80% 60% at 30% 30%,rgba(212,175,55,0.05) 0%,transparent 70%);pointer-events:none;}

/* Corner accents */
.msg-card-big .corner{position:absolute;width:18px;height:18px;}
.msg-card-big .corner.tl{top:12px;left:12px;border-top:2px solid rgba(212,175,55,0.5);border-left:2px solid rgba(212,175,55,0.5);}
.msg-card-big .corner.tr{top:12px;right:12px;border-top:2px solid rgba(212,175,55,0.5);border-right:2px solid rgba(212,175,55,0.5);}
.msg-card-big .corner.bl{bottom:12px;left:12px;border-bottom:2px solid rgba(212,175,55,0.5);border-left:2px solid rgba(212,175,55,0.5);}
.msg-card-big .corner.br{bottom:12px;right:12px;border-bottom:2px solid rgba(212,175,55,0.5);border-right:2px solid rgba(212,175,55,0.5);}

.msg-ico-big{font-size:56px;line-height:1;margin-bottom:20px;animation:icoFloat 3s ease-in-out infinite;}
@keyframes icoFloat{0%,100%{transform:translateY(0) scale(1)}50%{transform:translateY(-10px) scale(1.05)}}
.msg-title{font-family:"Cinzel",serif;font-size:11px;font-weight:600;
  letter-spacing:0.45em;text-transform:uppercase;color:var(--gold);margin-bottom:12px;opacity:0.8;}
.msg-body{font-size:22px;font-weight:300;line-height:1.6;color:rgba(248,245,255,0.9);}
.msg-body b{color:#F0C040;font-weight:700;}
.msg-body em{color:rgba(248,245,255,0.5);font-style:normal;font-size:15px;display:block;margin-top:10px;}

/* DIVIDER */
.stage-divider{position:absolute;top:15%;bottom:15%;left:52%;width:1px;
  background:linear-gradient(180deg,transparent,rgba(212,175,55,0.3) 30%,rgba(212,175,55,0.3) 70%,transparent);
  opacity:0;transition:opacity 0.9s var(--ease);}
.stage-divider.visible{opacity:1;}

/* FOOTER */
.ftr{height:50px;flex-shrink:0;display:flex;align-items:center;justify-content:space-between;
  padding:0 52px;border-top:1px solid rgba(212,175,55,0.08);}
.ftr-l,.ftr-r{font-size:10px;letter-spacing:0.15em;text-transform:uppercase;color:rgba(212,175,55,0.22);}
/* ticker */
.ftr-ticker{overflow:hidden;flex:1;margin:0 40px;}
.ticker-inner{white-space:nowrap;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;
  color:rgba(212,175,55,0.2);animation:ticker 22s linear infinite;}
@keyframes ticker{from{transform:translateX(100%)}to{transform:translateX(-100%)}}

/* PROGRESS BAR */
#progBar{position:fixed;bottom:0;left:0;height:2px;
  background:linear-gradient(90deg,var(--gold-d),var(--gold-b));
  box-shadow:0 0 10px rgba(212,175,55,0.6);transition:width 1s linear;z-index:20;}

/* FINALE */
#finale{position:fixed;inset:0;z-index:100;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  background:var(--bg);opacity:0;pointer-events:none;transition:opacity 0.5s;}
#finale.on{opacity:1;pointer-events:all;}
.fin-rays{position:absolute;inset:0;
  background:conic-gradient(from 0deg at 50% 50%,
    rgba(212,175,55,0) 0deg,rgba(212,175,55,0.07) 12deg,rgba(212,175,55,0) 24deg,
    rgba(212,175,55,0.07) 36deg,rgba(212,175,55,0) 48deg,rgba(212,175,55,0.07) 60deg,
    rgba(212,175,55,0) 72deg,rgba(212,175,55,0.07) 84deg,rgba(212,175,55,0) 96deg,
    rgba(212,175,55,0.07) 108deg,rgba(212,175,55,0) 120deg,rgba(212,175,55,0.07) 132deg,
    rgba(212,175,55,0) 144deg,rgba(212,175,55,0.07) 156deg,rgba(212,175,55,0) 168deg,
    rgba(212,175,55,0.07) 180deg,rgba(212,175,55,0) 192deg,rgba(212,175,55,0.07) 204deg,
    rgba(212,175,55,0) 216deg,rgba(212,175,55,0.07) 228deg,rgba(212,175,55,0) 240deg,
    rgba(212,175,55,0.07) 252deg,rgba(212,175,55,0) 264deg,rgba(212,175,55,0.07) 276deg,
    rgba(212,175,55,0) 288deg,rgba(212,175,55,0.07) 300deg,rgba(212,175,55,0) 312deg,
    rgba(212,175,55,0.07) 324deg,rgba(212,175,55,0) 336deg,rgba(212,175,55,0.07) 348deg,rgba(212,175,55,0) 360deg);
  animation:rspin 4s linear infinite;}
.fin-glow{position:absolute;inset:0;
  background:radial-gradient(ellipse 55% 45% at 50% 50%,rgba(212,175,55,0.2) 0%,transparent 65%);}
@keyframes rspin{from{transform:rotate(0)}to{transform:rotate(360deg)}}
.fin-logo{height:64px;position:relative;z-index:2;opacity:0;animation:finIn 0.8s 0.1s var(--ease) forwards;}
.fin-line{width:240px;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);
  position:relative;z-index:2;margin:22px 0;opacity:0;animation:finIn 0.8s 0.3s var(--ease) forwards;}
.fin-big{font-family:"Cinzel",serif;font-size:72px;font-weight:900;
  background:linear-gradient(145deg,#F0C040 0%,#D4AF37 40%,#A8821A 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  letter-spacing:10px;text-align:center;position:relative;z-index:2;
  opacity:0;animation:finIn 0.8s 0.2s var(--ease) forwards;}
.fin-sub{font-size:13px;font-weight:400;letter-spacing:0.5em;text-transform:uppercase;
  color:rgba(212,175,55,0.5);position:relative;z-index:2;margin-top:10px;
  opacity:0;animation:finIn 0.8s 0.45s var(--ease) forwards;}
.fin-bg-num{font-family:"Cinzel",serif;font-size:220px;font-weight:900;
  color:rgba(212,175,55,0.04);position:absolute;bottom:-20px;right:5%;
  line-height:1;pointer-events:none;z-index:1;}
@keyframes finIn{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}
@keyframes flashIn{0%{background:rgba(212,175,55,0.15)}100%{background:rgba(8,6,18,0.78)}}
.msg-card-big.flash{animation:flashIn 0.5s ease-out;}

/* Number tick animation */
.tick-anim{animation:tickBounce 0.25s var(--ease);}
@keyframes tickBounce{0%{transform:translateY(-8px) scale(1.08);opacity:0.4}100%{transform:translateY(0) scale(1);opacity:1}}
</style>
</head>
<body>

<canvas id="cvRocks"></canvas>
<canvas id="cvStars"></canvas>
<canvas id="cvDust"></canvas>
<canvas id="cvBeams"></canvas>
<div class="vignette"></div>
<div class="bg-grid"></div>

<div class="shell">
  <header class="hdr">
    <img class="logo-img" src="data:image/png;base64," alt="Minttora">
    <div class="right-pills">
      <div class="zoom-pill">Lun – Vie &nbsp;·&nbsp; Colombia</div>
      <div class="live-pill"><span class="dot-live"></span>En Vivo</div>
    </div>
  </header>

  <div class="stage" id="stage">
    <div class="cd-panel" id="cdPanel">
      <div class="cd-label">La sesión inicia en</div>
      <div class="ring-wrap">
        <!-- pulse rings behind -->
        <div class="pulse-ring"></div>
        <div class="pulse-ring"></div>
        <div class="pulse-ring"></div>
        <svg class="ring-svg" viewBox="0 0 280 280">
          <defs>
            <linearGradient id="gGrad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#8A6A0A"/>
              <stop offset="45%" stop-color="#F0C040"/>
              <stop offset="100%" stop-color="#D4AF37"/>
            </linearGradient>
          </defs>
          <circle class="r-track" cx="140" cy="140" r="128"/>
          <circle id="ringProg" class="r-prog" cx="140" cy="140" r="128"
            stroke-dasharray="804.25" stroke-dashoffset="0"/>
        </svg>
        <div class="deco-a"></div>
        <div class="deco-b"></div>
        <div class="deco-c"></div>
        <div class="ring-scan"></div>
        <div class="time-center">
          <div id="timeDisp">8:00</div>
          <div id="unitDisp">minutos</div>
        </div>
      </div>
    </div>

    <div class="stage-divider" id="stageDivider"></div>

    <div class="msg-panel" id="msgPanel">
      <div class="msg-card-big" id="msgCard">
        <div class="corner tl"></div><div class="corner tr"></div>
        <div class="corner bl"></div><div class="corner br"></div>
        <div class="msg-ico-big" id="msgIco">👋</div>
        <div class="msg-title" id="msgTitle">BIENVENIDO/A</div>
        <div class="msg-body" id="msgBody">Estás a punto de descubrir<br><b>una oportunidad financiera real.</b><em>Prepárate. Esta sesión es para ti.</em></div>
      </div>
    </div>
  </div>

  <footer class="ftr">
    <span class="ftr-l">Minttora</span>
    <div class="ftr-ticker"><span class="ticker-inner">Inversión en Oro &nbsp;·&nbsp; Sistema Binario &nbsp;·&nbsp; Oportunidades Reales &nbsp;·&nbsp; Zoom en Vivo &nbsp;·&nbsp; Colombia &nbsp;·&nbsp; Lunes a Viernes &nbsp;·&nbsp; Bienvenido/a &nbsp;·&nbsp; Información de valor &nbsp;·&nbsp; Tu futuro financiero &nbsp;·&nbsp;</span></div>
    <span class="ftr-r">Zoom en Vivo</span>
  </footer>
</div>

<div id="progBar" style="width:100%"></div>

<div id="finale">
  <div class="fin-rays"></div>
  <div class="fin-glow"></div>
  <img class="fin-logo" src="data:image/png;base64," alt="Minttora">
  <div class="fin-big">COMENZAMOS</div>
  <div class="fin-line"></div>
  <div class="fin-sub">La sesión inicia ahora — ¡Bienvenidos!</div>
  <div class="fin-bg-num" id="finBgNum">5</div>
</div>

<script>
// ============================================================
// LAYER 1 — GOLD ROCKS  (parallax, 3D shading)
// ============================================================
(function(){
  const cv=document.getElementById("cvRocks"),cx=cv.getContext("2d");
  let W,H;
  function resize(){W=cv.width=innerWidth;H=cv.height=innerHeight;}
  resize();window.addEventListener("resize",resize);

  function makeVerts(n){
    const pts=[];
    for(let i=0;i<n;i++){
      const a=(i/n)*Math.PI*2+Math.random()*0.4;
      const r=0.65+Math.random()*0.6;
      pts.push([Math.cos(a)*r,Math.sin(a)*r]);
    }
    return pts;
  }

  const rocks=Array.from({length:26},(_,idx)=>{
    const depth=0.15+Math.random()*0.85;
    const size=14+Math.random()*58;
    return{
      x:Math.random()*1.4-0.2, y:Math.random()*1.4-0.2,
      vx:(Math.random()-0.5)*0.00014*(0.3+depth*0.7),
      vy:(Math.random()-0.5)*0.00009*(0.3+depth*0.7),
      rot:Math.random()*Math.PI*2,
      vrot:(Math.random()-0.5)*0.0035*(0.4+depth*0.6),
      size, depth,
      verts:makeVerts(7+Math.floor(Math.random()*5)),
      h:36+Math.random()*18, sat:48+Math.random()*32, lit:28+Math.random()*26,
      alpha:0.1+depth*0.3, glowAlpha:0.04+depth*0.14,
      // shimmer phase
      shimmer:Math.random()*Math.PI*2, shimmerSpeed:0.008+Math.random()*0.012,
    };
  });
  // Sort back-to-front by depth
  rocks.sort((a,b)=>a.depth-b.depth);

  function drawRock(r){
    r.shimmer+=r.shimmerSpeed;
    const shimAmt=0.5+Math.sin(r.shimmer)*0.5;
    const px=r.x*W, py=r.y*H;
    cx.save(); cx.translate(px,py); cx.rotate(r.rot);
    const s=r.size;

    // outer glow (pulsing)
    const grd=cx.createRadialGradient(0,0,s*0.1,0,0,s*(1.5+shimAmt*0.3));
    grd.addColorStop(0,`hsla(${r.h},${r.sat}%,${r.lit+20}%,${r.glowAlpha*(0.7+shimAmt*0.6)})`);
    grd.addColorStop(1,"transparent");
    cx.beginPath(); cx.arc(0,0,s*1.8,0,Math.PI*2);
    cx.fillStyle=grd; cx.fill();

    // rock face
    cx.beginPath();
    cx.moveTo(r.verts[0][0]*s,r.verts[0][1]*s);
    r.verts.forEach(([vx,vy])=>cx.lineTo(vx*s,vy*s));
    cx.closePath();
    const face=cx.createLinearGradient(-s*0.6,-s*0.6,s*0.6,s*0.6);
    face.addColorStop(0,  `hsla(${r.h+6},${r.sat+12}%,${r.lit+24+shimAmt*8}%,${r.alpha})`);
    face.addColorStop(0.4,`hsla(${r.h},${r.sat}%,${r.lit}%,${r.alpha})`);
    face.addColorStop(1,  `hsla(${r.h-4},${r.sat-18}%,${r.lit-14}%,${r.alpha*0.65})`);
    cx.fillStyle=face; cx.fill();

    // rim highlight
    cx.strokeStyle=`hsla(${r.h+8},${r.sat+14}%,${r.lit+32}%,${r.alpha*(0.4+shimAmt*0.4)})`;
    cx.lineWidth=0.9; cx.stroke();

    // specular bright spot
    cx.beginPath();
    cx.arc(-s*0.22,-s*0.26,s*(0.06+shimAmt*0.04),0,Math.PI*2);
    cx.fillStyle=`hsla(50,100%,92%,${r.alpha*(0.5+shimAmt*0.7)})`; cx.fill();

    // secondary smaller spec
    cx.beginPath();
    cx.arc(-s*0.1,-s*0.4,s*0.025,0,Math.PI*2);
    cx.fillStyle=`hsla(48,100%,98%,${r.alpha*0.6})`; cx.fill();

    cx.restore();
  }

  function animRocks(){
    cx.clearRect(0,0,W,H);
    rocks.forEach(r=>{
      r.x+=r.vx; r.y+=r.vy; r.rot+=r.vrot;
      if(r.x<-0.28)r.x=1.18; if(r.x>1.28)r.x=-0.18;
      if(r.y<-0.28)r.y=1.18; if(r.y>1.28)r.y=-0.18;
      drawRock(r);
    });
    requestAnimationFrame(animRocks);
  }
  animRocks();
})();

// ============================================================
// LAYER 2 — STARS + SPARKLES
// ============================================================
(function(){
  const cv=document.getElementById("cvStars"),cx=cv.getContext("2d");
  let W,H;
  function resize(){W=cv.width=innerWidth;H=cv.height=innerHeight;}
  resize();window.addEventListener("resize",resize);

  const stars=Array.from({length:140},()=>({
    x:Math.random(), y:Math.random(),
    r:Math.random()*1.3+0.2,
    tw:Math.random()*Math.PI*2, tws:0.018+Math.random()*0.04,
    gold:Math.random()>0.5,
    vx:(Math.random()-0.5)*0.00005,vy:(Math.random()-0.5)*0.00005,
  }));

  const sparkles=Array.from({length:22},()=>({
    x:Math.random(), y:Math.random(),
    size:3+Math.random()*10,
    rot:Math.random()*Math.PI, vrot:(Math.random()-0.5)*0.018,
    tw:Math.random()*Math.PI*2, tws:0.012+Math.random()*0.022,
    vx:(Math.random()-0.5)*0.00007,vy:(Math.random()-0.5)*0.00007,
  }));

  // Shooting stars
  const shoots=[];
  function spawnShoot(){
    shoots.push({
      x:Math.random()*0.8+0.1, y:Math.random()*0.4,
      len:60+Math.random()*100,
      vx:1.5+Math.random()*2, vy:0.5+Math.random()*1.2,
      alpha:0.8, life:0
    });
  }
  setInterval(spawnShoot,3500+Math.random()*2000);

  function drawSparkle(x,y,sz,rot,alpha){
    cx.save(); cx.translate(x,y); cx.rotate(rot);
    cx.globalAlpha=alpha;
    cx.strokeStyle="rgba(240,192,64,1)"; cx.lineWidth=0.9;
    cx.beginPath();
    cx.moveTo(0,-sz);cx.lineTo(0,sz);
    cx.moveTo(-sz,0);cx.lineTo(sz,0);
    cx.moveTo(-sz*0.55,-sz*0.55);cx.lineTo(sz*0.55,sz*0.55);
    cx.moveTo(sz*0.55,-sz*0.55);cx.lineTo(-sz*0.55,sz*0.55);
    cx.stroke();
    cx.beginPath();cx.arc(0,0,sz*0.16,0,Math.PI*2);
    cx.fillStyle="rgba(255,240,160,1)";cx.fill();
    cx.restore();
  }

  function animStars(){
    cx.clearRect(0,0,W,H);
    // dots
    stars.forEach(s=>{
      s.x+=s.vx;s.y+=s.vy;s.tw+=s.tws;
      if(s.x<0)s.x=1;if(s.x>1)s.x=0;if(s.y<0)s.y=1;if(s.y>1)s.y=0;
      const a=0.3+Math.sin(s.tw)*0.38;
      cx.beginPath();cx.arc(s.x*W,s.y*H,s.r,0,Math.PI*2);
      cx.fillStyle=s.gold?`rgba(212,175,55,${a*0.85})`:`rgba(200,200,255,${a*0.45})`;
      cx.shadowBlur=s.gold?7:2;cx.shadowColor=s.gold?"#D4AF37":"#aaaaff";
      cx.fill();
    });
    cx.shadowBlur=0;
    // sparkles
    sparkles.forEach(s=>{
      s.x+=s.vx;s.y+=s.vy;s.rot+=s.vrot;s.tw+=s.tws;
      if(s.x<0)s.x=1;if(s.x>1)s.x=0;if(s.y<0)s.y=1;if(s.y>1)s.y=0;
      const a=0.08+Math.abs(Math.sin(s.tw))*0.5;
      drawSparkle(s.x*W,s.y*H,s.size,s.rot,a);
    });
    // shooting stars
    for(let i=shoots.length-1;i>=0;i--){
      const s=shoots[i];
      s.x+=s.vx*0.003;s.y+=s.vy*0.003;s.life++;s.alpha-=0.015;
      if(s.alpha<=0||s.x>1.1||s.y>1.0){shoots.splice(i,1);continue;}
      cx.save();
      cx.globalAlpha=s.alpha*0.7;
      const grd=cx.createLinearGradient(s.x*W,s.y*H,(s.x*W-s.vx*s.len*0.003),(s.y*H-s.vy*s.len*0.003));
      grd.addColorStop(0,"rgba(240,192,64,0.9)");
      grd.addColorStop(1,"transparent");
      cx.beginPath();cx.moveTo(s.x*W,s.y*H);
      cx.lineTo((s.x*W-s.vx*s.len*0.003),(s.y*H-s.vy*s.len*0.003));
      cx.strokeStyle=grd;cx.lineWidth=1.5;
      cx.shadowBlur=6;cx.shadowColor="#F0C040";
      cx.stroke();cx.restore();
    }
    requestAnimationFrame(animStars);
  }
  animStars();
})();

// ============================================================
// LAYER 3 — MICRO DUST
// ============================================================
(function(){
  const cv=document.getElementById("cvDust"),cx=cv.getContext("2d");
  let W,H;
  function resize(){W=cv.width=innerWidth;H=cv.height=innerHeight;}
  resize();window.addEventListener("resize",resize);
  const pts=Array.from({length:70},()=>({
    x:Math.random(),y:Math.random(),
    r:Math.random()*1.5+0.2,
    vy:-(Math.random()*0.00035+0.00008),
    vx:(Math.random()-0.5)*0.00018,
    a:Math.random()*0.28+0.04,
    life:Math.random()*400,maxLife:Math.random()*200+130,
    gold:Math.random()>0.3,
    wobble:Math.random()*Math.PI*2,wobbleSpeed:0.02+Math.random()*0.03,
  }));
  function loop(){
    cx.clearRect(0,0,W,H);
    pts.forEach(p=>{
      p.wobble+=p.wobbleSpeed;
      p.x+=p.vx+Math.sin(p.wobble)*0.00008;
      p.y+=p.vy;p.life++;
      if(p.life>p.maxLife||p.y<-0.02){
        p.x=Math.random();p.y=1.02;p.life=0;
        p.maxLife=Math.random()*200+110;p.r=Math.random()*1.5+0.2;
      }
      const ph=Math.sin(p.life/p.maxLife*Math.PI);
      cx.save();cx.globalAlpha=p.a*ph;
      cx.fillStyle=p.gold?"#D4AF37":"#9B79FF";
      cx.shadowBlur=5;cx.shadowColor=p.gold?"#F0C040":"#9B79FF";
      cx.beginPath();cx.arc(p.x*W,p.y*H,p.r,0,Math.PI*2);cx.fill();
      cx.restore();
    });
    requestAnimationFrame(loop);
  }
  loop();
})();

// ============================================================
// LAYER 4 — LIGHT BEAMS / AURORA SWEEPS
// ============================================================
(function(){
  const cv=document.getElementById("cvBeams"),cx=cv.getContext("2d");
  let W,H;
  function resize(){W=cv.width=innerWidth;H=cv.height=innerHeight;}
  resize();window.addEventListener("resize",resize);

  const beams=[
    {x:0.25,width:180,speed:0.00008,phase:0,      alpha:0.022,color:"212,175,55"},
    {x:0.6, width:120,speed:0.00012,phase:1.2,    alpha:0.016,color:"212,175,55"},
    {x:0.78,width:200,speed:0.00006,phase:2.5,    alpha:0.018,color:"123,92,240"},
    {x:0.45,width:90, speed:0.00015,phase:0.7,    alpha:0.012,color:"212,175,55"},
  ];
  let t=0;
  function animBeams(){
    cx.clearRect(0,0,W,H);
    t+=0.5;
    beams.forEach(b=>{
      const cx2=((b.x+Math.sin(t*b.speed+b.phase)*0.12)*W);
      const grd=cx.createLinearGradient(cx2-b.width,0,cx2+b.width,H);
      grd.addColorStop(0,"transparent");
      grd.addColorStop(0.5,`rgba(${b.color},${b.alpha})`);
      grd.addColorStop(1,"transparent");
      cx.fillStyle=grd;
      cx.fillRect(0,0,W,H);
    });
    requestAnimationFrame(animBeams);
  }
  animBeams();
})();

