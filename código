  {at: 60,ico:"⚡",title:"¡YA CASI!",         body:"En menos de 1 minuto<br><b>iniciamos la sesión.</b><em>Hoy aprenderás algo que vale oro.</em>"},
];

const TOTAL=8*60,CIRC=804.25;
let sLeft=TOTAL,finaleDone=false,msgTimeout=null,lastSecond=-1;

function fmt(s){const m=Math.floor(s/60),sec=s%60;return m+":"+(sec<10?"0":"")+sec;}

function tick(){
  if(sLeft===lastSecond)return;
  lastSecond=sLeft;

  const td=document.getElementById("timeDisp");
  if(sLeft>5){
    td.textContent=fmt(sLeft);
    document.getElementById("unitDisp").textContent=sLeft>=60?"minutos":"segundos";
  } else if(sLeft>0){
    td.textContent=sLeft;
    document.getElementById("unitDisp").textContent="segundos";
  }
  // tick bounce
  td.classList.remove("tick-anim");void td.offsetWidth;td.classList.add("tick-anim");

  const off=CIRC*(1-sLeft/TOTAL);
  document.getElementById("ringProg").style.strokeDashoffset=off;
  document.getElementById("progBar").style.width=(sLeft/TOTAL*100)+"%";

  MSGS.forEach(m=>{if(sLeft===m.at)triggerMsg(m);});
  if(sLeft<=5&&!finaleDone)triggerFinale();
  if(sLeft>0)sLeft--;
}

function triggerMsg(m){
  clearTimeout(msgTimeout);
  document.getElementById("msgIco").textContent=m.ico;
  document.getElementById("msgTitle").textContent=m.title;
  document.getElementById("msgBody").innerHTML=m.body;
  const card=document.getElementById("msgCard");
  card.classList.remove("flash");void card.offsetWidth;card.classList.add("flash");
  document.getElementById("cdPanel").classList.add("shifted");
  document.getElementById("msgPanel").classList.add("visible");
  document.getElementById("stageDivider").classList.add("visible");
  msgTimeout=setTimeout(hideMsg,50000);
}
function hideMsg(){
  document.getElementById("cdPanel").classList.remove("shifted");
  document.getElementById("msgPanel").classList.remove("visible");
  document.getElementById("stageDivider").classList.remove("visible");
}
function triggerFinale(){
  finaleDone=true;clearTimeout(msgTimeout);hideMsg();
  document.getElementById("finale").classList.add("on");
  let fc=5;const fcEl=document.getElementById("finBgNum");
  const fi=setInterval(()=>{fc--;fcEl.textContent=fc>0?fc:"";if(fc<=0)clearInterval(fi);},1000);
}

window.addEventListener("load",()=>{
  tick();
  setInterval(tick,1000);
  setTimeout(()=>triggerMsg(MSGS[0]),1200);
});
